{
    "compilerOptions": {
      "target":            "ES2024",
      "lib":               [ "ES2024" ],
      "module":            "NodeNext",
      "moduleResolution":  "NodeNext",
      "types":             [ "node" ],
      "outDir":            "./dist",
      "rootDir":           ".",
      "composite":         true,
      "strict":            true,
      "resolveJsonModule": true,
      "esModuleInterop":   true,
      "skipLibCheck":      true,
      "declaration":       true,
      "sourceMap":         false
    },
    "include": [ "bash-authorize-api.ts", "bash-authorize-cli.ts" ],
    "exclude": [ "node_modules", "dist" ]
}
