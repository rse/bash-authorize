{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type":          "command",
                        "command":       "node \"${CLAUDE_PLUGIN_ROOT}/dist/bash-authorize-cli.js\"",
                        "statusMessage": "Authorizing Bash command..."
                    }
                ]
            }
        ]
    }
}
